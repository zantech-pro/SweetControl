{
  "expo": {
    "name": "mobile",
    "slug": "mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.zantechpro.mobile",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "backgroundColor": "#E6F4FE",
      "edgeToEdgeEnabled": true,
      "package": "com.zantechpro.mobile"
    },
    "plugins": [
      "expo-router",
      "@react-native-community/datetimepicker"
    ],
    "extra": {
      "eas": {
        "projectId": "4b76ac42-bdb4-46e2-ba4b-b76ee1d5820e"
      }
    }
  }
}
