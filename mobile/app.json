{
  "expo": {
    "name": "SweetControl",
    "slug": "sweetcontrol",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "icon": "./assets/images/icon-1024.png",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.zantechpro.mobile",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "Precisamos da camera para permitir foto de perfil.",
        "NSPhotoLibraryUsageDescription": "Precisamos da galeria para permitir foto de perfil."
      }
    },
    "android": {
      "backgroundColor": "#E6F4FE",
      "edgeToEdgeEnabled": true,
      "package": "com.zantechpro.mobile",
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "READ_MEDIA_IMAGES"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/android-adaptive-foreground.png",
        "backgroundColor": "#FFFFFF",
        "monochromeImage": "./assets/images/android-adaptive-monochrome.png"
      }
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "@react-native-community/datetimepicker",
      "expo-image-picker"
    ],
    "extra": {
      "eas": {
        "projectId": "4b76ac42-bdb4-46e2-ba4b-b76ee1d5820e"
      }
    }
  }
}
